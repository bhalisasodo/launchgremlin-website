# Backend lead submission settings
EMAIL_TO=bhalisasodo10@gmail.com
EMAIL_FROM=no-reply@launchgremlin.com

# SMTP configuration for sending email directly
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Optional webhook fallback or integration endpoint
# WEBHOOK_URL=https://hooks.example.com/your-webhook-path

# Optional local webhook receiver for review/testing
# WEBHOOK_URL=http://localhost:4000/api/webhook-receiver

# Optional local lead log file path for production auditing
LEAD_LOG_PATH=logs/leads.log

# Rate limiting for the lead API (milliseconds and max requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30
